## 🧭 Expo Router

### File-Based Routing
- Use `(group)` for route groups (tabs, auth, modal)
- Use `[param]` for dynamic routes
- Use `_layout.tsx` for nested navigation
- Use `+not-found.tsx` for 404 handling

### Navigation Best Practices
```typescript
// ✅ GOOD - Type-safe navigation
import { Link, useRouter, router } from 'expo-router';

<Link href="/user/123">View User</Link>
router.push({ pathname: '/user/[id]', params: { id: '123' } });

// ❌ BAD - String-only navigation
router.push('/user/123');
```

### Typed Routes
```typescript
import { useLocalSearchParams } from 'expo-router';

// In app/user/[id].tsx
const { id } = useLocalSearchParams<{ id: string }>();
```

### Layout Configuration
```typescript
// app/_layout.tsx
import { Stack } from 'expo-router';
import { GestureHandlerRootView } from 'react-native-gesture-handler';

export default function RootLayout() {
  return (
    <GestureHandlerRootView className="flex-1">
      <Stack screenOptions={{ headerShown: false }}>
        <Stack.Screen name="(tabs)" />
        <Stack.Screen name="(auth)" options={{ presentation: 'modal' }} />
      </Stack>
    </GestureHandlerRootView>
  );
}
```

