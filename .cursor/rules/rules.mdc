## 💾 React Native MMKV

### Storage Utility
```typescript
// src/utils/storage.ts
import { MMKV } from 'react-native-mmkv';
import { StateStorage } from 'zustand/middleware';

export const storage = new MMKV();

export enum StorageKeys {
  AUTH_TOKEN = 'auth_token',
  USER_PREFS = 'user_preferences',
  THEME = 'theme',
  LANGUAGE = 'language',
}

export const Storage = {
  getString: (key: StorageKeys) => storage.getString(key),
  setString: (key: StorageKeys, value: string) => storage.set(key, value),
  getNumber: (key: StorageKeys) => storage.getNumber(key),
  setNumber: (key: StorageKeys, value: number) => storage.set(key, value),
  getBoolean: (key: StorageKeys) => storage.getBoolean(key),
  setBoolean: (key: StorageKeys, value: boolean) => storage.set(key, value),
  
  getObject: <T>(key: StorageKeys): T | null => {
    const value = storage.getString(key);
    return value ? JSON.parse(value) : null;
  },
  
  setObject: <T>(key: StorageKeys, value: T) => {
    storage.set(key, JSON.stringify(value));
  },
  
  delete: (key: StorageKeys) => storage.delete(key),
  clearAll: () => storage.clearAll(),
};

export const zustandStorage: StateStorage = {
  setItem: (name, value) => storage.set(name, value),
  getItem: (name) => storage.getString(name) ?? null,
  removeItem: (name) => storage.delete(name),
};
```

